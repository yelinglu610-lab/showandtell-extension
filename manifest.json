{
  "manifest_version": 3,
  "name": "ShowAndTell",
  "version": "2.2.0",
  "description": "激光笔 · 摄像头 · 录制 · 悬浮工具栏",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ShowAndTell — 点击激活"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [{
    "resources": ["src/content.css", "src/content.js"],
    "matches": ["<all_urls>"]
  }]
}
